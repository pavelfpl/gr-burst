<?xml version="1.0"?>
<block>
  <name>Burst Frame Align</name>
  <key>burst_framealign</key>
  <category>burst</category>
  <import>import burst</import>
  <make>burst.framealign($skip, $blocksize, $blocks, $shape_bits)</make>

  <param>
    <name>Skip</name>
    <key>skip</key>
    <value>24</value>
    <type>int</type>
  </param>
  
  <param>
    <name>Blocksize</name>
    <key>blocksize</key>
    <value>1024</value>
    <type>int</type>
  </param>
  
  <param>
    <name>Num. of blocks</name>
    <key>blocks</key>
    <value>0</value>
    <type>int</type>
  </param>
  
  <param>
    <name>Shape Soft Bits</name>
    <key>shape_bits</key>
    <value>False</value>
    <type>bool</type>
    <option>
        <name>Yes</name>
        <key>True</key>
    </option>
    <option>
        <name>No</name>
        <key>False</key>
    </option>
  </param>
  
  <sink>
    <name>fpdus</name>
    <type>message</type>
    <optional>1</optional>
  </sink>

  <source>
    <name>fpdus</name>
    <type>message</type>
    <optional>1</optional>
  </source>
</block>
