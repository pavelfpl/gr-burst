<?xml version="1.0"?>
<block>
  <name>Burst Scheduler</name>
  <key>burst_scheduler</key>
  <category>burst</category>
  <import>import burst</import>
  <make>burst.burst_scheduler($barrier, $slot)</make>
  <param>
    <name>Packet barrier</name>
    <key>barrier</key>
    <value>10000</value>
    <type>int</type>
  </param>
  <param>
    <name>Slot</name>
    <key>slot</key>
    <value>1000</value>
    <type>int</type>
  </param>  
  <sink>
    <name>sched_pdu</name>
    <type>message</type>
    <optional>1</optional>
  </sink>

  <sink>
    <name>nproduced</name>
    <type>message</type>
    <optional>1</optional>
  </sink>

  <source>
    <name>sched_pdu</name>
    <type>message</type>
    <optional>1</optional>
  </source>

</block>
